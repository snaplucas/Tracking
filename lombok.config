# Stop Lombok from looking for config files further up the tree.
config.stopBubbling = true

# Copy Spring's @Value / @Qualifier from fields onto the constructor parameters
# generated by @RequiredArgsConstructor, so property/bean injection still works.
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Value
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Qualifier
